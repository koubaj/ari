    <P Name="C">eye(4)</P>
    <P Name="D">zeros(4, 3)</P>
    <P Name="InitialCondition">0</P>
    <PortProperties>
      <Port Type="out" Index="1">
        <P Name="Name">Down</P>
      </Port>
    </PortProperties>
  </Block>
  <Block BlockType="StateSpace" Name="Observer Up" SID="174">
