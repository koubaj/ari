    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
    <P Name="Bias">90</P>
    <P Name="SaturateOnIntegerOverflow">off</P>
  </Block>
  <Block BlockType="Bias" Name="Add Constant1" SID="65">
    <P Name="Position">[655, 185, 695, 215]</P>
    <P Name="ZOrder">320</P>
    <P Name="Bias">90</P>
    <P Name="SaturateOnIntegerOverflow">off</P>
    <PortProperties>
      <Port Type="out" Index="1">
        <P Name="Name">orig phi</P>
      </Port>
    </PortProperties>
  </Block>
  <Block BlockType="Constant" Name="Constant" SID="68">
    <P Name="Position">[785, -90, 815, -60]</P>
    <P Name="ZOrder">323</P>
    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
    <P Name="Value">-0.5</P>
  </Block>
  <Block BlockType="Fcn" Name="Deadzone" SID="88">
    <P Name="Position">[370, -90, 430, -60]</P>
    <P Name="ZOrder">340</P>
    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
    <P Name="Expr">(u&lt;0.2)*u+(u&gt;0.2)*u</P>
  </Block>
  <Block BlockType="Demux" Name="Demux" SID="63">
    <PortCounts in="1" out="2"/>
    <P Name="Position">[475, 291, 480, 329]</P>
    <P Name="ZOrder">318</P>
    <P Name="Outputs">2</P>
    <PortProperties>
      <Port Type="out" Index="1">
        <P Name="Name">linear x</P>
      </Port>
    </PortProperties>
  </Block>
  <Block BlockType="Derivative" Name="Derivative2" SID="55">
    <P Name="Position">[395, 420, 425, 450]</P>
    <P Name="ZOrder">310</P>
    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
  </Block>
  <Block BlockType="ManualSwitch" Name="Manual Switch" SID="89">
    <P Name="Position">[285, -103, 315, -67]</P>
    <P Name="ZOrder">341</P>
    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
    <P Name="CurrentSetting">0</P>
  </Block>
  <Block BlockType="ManualSwitch" Name="Manual Switch1" SID="90">
    <P Name="Position">[667, 25, 703, 55]</P>
    <P Name="ZOrder">342</P>
    <P Name="BlockRotation">270</P>
    <P Name="NameLocation">right</P>
    <P Name="CurrentSetting">0</P>
  </Block>
  <Block BlockType="Gain" Name="Multiply" SID="48">
    <P Name="Position">[65, 50, 95, 80]</P>
    <P Name="ZOrder">303</P>
  </Block>
  <Block BlockType="Gain" Name="Multiply1" SID="49">
    <P Name="Position">[295, 420, 325, 450]</P>
    <P Name="ZOrder">304</P>
    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
    <P Name="Gain">0.1</P>
  </Block>
  <Block BlockType="Gain" Name="Multiply2" SID="66">
    <P Name="Position">[545, 305, 575, 335]</P>
    <P Name="ZOrder">321</P>
    <P Name="Gain">180/pi</P>
    <PortProperties>
      <Port Type="out" Index="1">
        <P Name="Name">linear phi</P>
      </Port>
    </PortProperties>
  </Block>
  <Block BlockType="SubSystem" Name="PENDULUM &#xA;VR Model" SID="1">
    <PortCounts in="1" out="2"/>
    <P Name="Position">[445, 70, 630, 245]</P>
    <P Name="ZOrder">-1</P>
    <Mask>
      <Type>Pendulum</Type>
      <Display>image(imread(&apos;Pendulum_Image.jpg&apos;))
port_label (&apos;input&apos;,1,&apos;F&apos;)
port_label (&apos;output&apos;,1,&apos;x&apos;)
port_label (&apos;output&apos;,2,&apos;phi&apos;)</Display>
      <Description>Pendulum - Virtual Reality</Description>
      <Initialization>clear figureVR worldVR;
showVR = 1;</Initialization>
      <Help>Pendulum - Virtual Reality. &lt;br&gt;&lt;br&gt;

This is a model of the inverted pendulum on a cart, which consit of a beam and a cart. The beam is connected with the cart by a pivot. The input of this system is mechanical force applied on the cart, outputs are the angle of the beam and the position of the cart.   &lt;br&gt;&lt;br&gt;


In the mask of the model, it can be set:
&lt;ul&gt;
&lt;li&gt;Initial angle of the pendulum&lt;/li&gt;
&lt;/ul&gt;&lt;br&gt;&lt;br&gt;


Copyright: 2007,   Jan Vana, Jirka Roubal, Petr Husek.</Help>
      <MaskParameter Name="showVR" Type="checkbox">
        <Prompt>Show Virtual World?</Prompt>
        <Value>on</Value>
        <Callback>if strcmp(&apos;off&apos;,get_param(gcb,&apos;showVR&apos;))
    vrclose all;
else
    if exist(&apos;figureVR&apos;)==0
        figureVR = vrfigure;
    end  
    if exist(&apos;worldVR&apos;)==0
        worldVR = vrworld(&apos;Pendulum_VR.WRL&apos;);
    end
	if isvalid(figureVR)==0
        open(worldVR);
        figureVR = vrfigure(worldVR,[650 80 550 350]);
	end
end</Callback>
      </MaskParameter>
      <MaskParameter Name="phi0" Type="edit">
        <Prompt>Initial angle of the pendulum   phi(0) [deg] (from horizontal plane)</Prompt>
        <Value>-90</Value>
      </MaskParameter>
      <MaskParameter Name="y0" Type="edit">
        <Prompt>Initial position of the cart x0 [m] (rightwise from the center)</Prompt>
        <Value>0</Value>
      </MaskParameter>
      <MaskParameter Name="brake" Type="checkbox">
        <Prompt>Cart brake</Prompt>
        <Value>off</Value>
      </MaskParameter>
      <MaskParameter Name="rail_bound" Type="checkbox">
        <Prompt>Obey rail boundaries</Prompt>
        <Value>off</Value>
      </MaskParameter>
      <DialogControl Type="Group" Name="DescGroupVar">
        <Prompt>%&lt;MaskType&gt;</Prompt>
        <DialogControl Type="Text" Name="DescTextVar">
          <Prompt>%&lt;MaskDescription&gt;</Prompt>
        </DialogControl>
      </DialogControl>
      <DialogControl Type="Group" Name="ParameterGroupVar">
        <Prompt>Simulink:studio:ToolBarParametersMenu</Prompt>
        <DialogControl Type="CheckBox" Name="showVR">
          <Prompt>Show Virtual World?</Prompt>
        </DialogControl>
        <DialogControl Type="Edit" Name="phi0">
          <Prompt>Initial angle of the pendulum   phi(0) [deg] (from horizontal plane)</Prompt>
        </DialogControl>
        <DialogControl Type="Edit" Name="y0">
          <Prompt>Initial position of the cart x0 [m] (rightwise from the center)</Prompt>
        </DialogControl>
        <DialogControl Type="CheckBox" Name="brake">
          <Prompt>Cart brake</Prompt>
        </DialogControl>
        <DialogControl Type="CheckBox" Name="rail_bound">
          <Prompt>Obey rail boundaries</Prompt>
        </DialogControl>
      </DialogControl>
    </Mask>
    <PortProperties>
      <Port Type="out" Index="1">
        <P Name="Name">orig x</P>
      </Port>
    </PortProperties>
    <System Ref="system_1"/>
  </Block>
  <Block BlockType="Reference" Name="PID Controller" SID="76">
    <PortCounts in="1" out="1"/>
    <P Name="Position">[565, -93, 605, -57]</P>
    <P Name="ZOrder">330</P>
    <P Name="BlockMirror">on</P>
    <P Name="NameLocation">top</P>
    <P Name="LibrarySourceBlock">simulink/Continuous/PID Controller</P>
    <P Name="LibraryVersion">11.0</P>
    <P Name="SourceBlock">slpidlib/PID Controller</P>
    <P Name="SourceType">PID 1dof</P>
    <InstanceData>
      <P Name="RTWMemSecFuncInitTerm">Inherit from model</P>
      <P Name="RTWMemSecFuncExecute">Inherit from model</P>
      <P Name="RTWMemSecDataConstants">Inherit from model</P>
      <P Name="RTWMemSecDataInternal">Inherit from model</P>
      <P Name="RTWMemSecDataParameters">Inherit from model</P>
      <P Name="ContentPreviewEnabled">on</P>
      <P Name="Controller">PID</P>
      <P Name="Form">Parallel</P>
      <P Name="TimeDomain">Continuous-time</P>
      <P Name="UseExternalTs">off</P>
      <P Name="SampleTime">-1</P>
      <P Name="IntegratorMethod">Forward Euler</P>
      <P Name="FilterMethod">Forward Euler</P>
      <P Name="ControllerParametersSource">internal</P>
      <P Name="P">1.8617</P>
      <P Name="I">0.12315</P>
      <P Name="UseKiTs">off</P>
