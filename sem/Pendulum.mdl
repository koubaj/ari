    <P Name="FontName">Arial</P>
  </BlockDefaults>
  <AnnotationDefaults>
    <P Name="HorizontalAlignment">center</P>
    <P Name="VerticalAlignment">middle</P>
    <P Name="FontName">Arial</P>
  </AnnotationDefaults>
  <LineDefaults>
